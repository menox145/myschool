<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve only files from Laravel's public directory.
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -d
    RewriteRule ^(.+)$ public/$1 [L]

    # Block application and configuration files from direct web access.
    RewriteRule ^(?:app|bootstrap|config|database|resources|routes|storage|tests|vendor)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:artisan|composer\.(?:json|lock)|package\.json|phpunit\.xml|vite\.config\.js)$ - [F,L,NC]
    RewriteRule (^|/)\. - [F,L]

    RewriteRule ^ public/index.php [L]
</IfModule>

Options -Indexes
